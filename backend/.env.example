# SkyX Backend Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb://admin:skyx_dev_password@localhost:27017/skyx?authSource=admin

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# JWT Configuration (optional, for enhanced security)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=24h

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# External Services
STRIPE_API_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# Logging
LOG_LEVEL=debug

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_ENDPOINT=https://analytics.skyxventures.com

# Feature Flags
ENABLE_REFERRAL_BONUS=true
ENABLE_GAME_REWARDS=true
ENABLE_TASK_VERIFICATION=true
